# =============================================================================
# Amazon EMR Spark Alert Reduction — Configuration template
# =============================================================================
# Copy this file to config.env and fill in your own values.
# config.env is gitignored so your values never enter version control.
#
# Prerequisites: Deploy Amazon EMR on Amazon EKS first using the data-on-eks
# blueprint: https://awslabs.github.io/data-on-eks/docs/blueprints/amazon-emr-on-eks/emr-eks-karpenter
#
# How to find these values after deployment:
#   EKS_CLUSTER_NAME:       aws eks list-clusters --region <your-region>
#   EMR_VIRTUAL_CLUSTER_ID: aws emr-containers list-virtual-clusters --states RUNNING --region <your-region>
#                           (use the Id for emr-data-team-a)
#   JOB_EXECUTION_ROLE_ARN: aws iam list-roles --query "Roles[?contains(RoleName,'emr-data-team-a')].Arn" --output text

# Required — identifiers from your Amazon EMR on Amazon EKS deployment
EKS_CLUSTER_NAME=<your-eks-cluster-name>
EMR_VIRTUAL_CLUSTER_ID=<your-virtual-cluster-id>
JOB_EXECUTION_ROLE_ARN=arn:aws:iam::<your-account-id>:role/<your-emr-execution-role>
AWS_REGION=<your-region>
ENVIRONMENT_NAME=dev

# Required — Amazon EKS namespace where Amazon EMR jobs run
EKS_NAMESPACE=emr-data-team-a

# Amazon CloudWatch log group for Amazon EMR on Amazon EKS job logs
EMR_LOG_GROUP=/emr-on-eks/dev

